# ──────────────────────────────────────────────────────────────────
# Validate user input
# ──────────────────────────────────────────────────────────────────
diskguard_validate_input_perc() {
    if [[ -z $1 ]] ; then
        #prevent polluting the output
        unset title body
        # prepare new output
        local title body
        title=("⚡ ${DISKGUARD_COLOR_YELLOW_BOLD}[DiskGuard] - User action required!${DISKGUARD_COLOR_NC}")
        body=("${DISKGUARD_COLOR_GREEN}Enter a value for the threshold in percent: ${DISKGUARD_COLOR_NC}")
        # display output
        #clear
        diskguard_print_box \
        "${title[@]}" \
        "${body[@]}"
        read -r input
        if [[ ! ${input} =~ '^([0-9]+)([a-zA-Z%%]*)$' ]] ; then
            #prevent polluting the output
            unset title body
            # prepare new output
            local title body
            title=("‼️ ${DISKGUARD_COLOR_YELLOW_BOLD}Information!${DISKGUARD_COLOR_NC}")
            body=("Empty input! Using the default value of (${DISKGUARD_COLOR_GREEN}80%%${DISKGUARD_COLOR_NC}).")
            # display output
            clear
            diskguard_print_box \
            "${title[@]}" \
            "${body[@]}"
            val=80
            return 0
        fi
    else
        input=$1
    fi
    # remove spaces
    input="${input//[[:space:]]/}"

    if [[ $input =~ '^([0-9]+)([a-zA-Z%%]*)$' ]]; then
        # Separate number and unit
        number="${match[1]}"
        unit="${match[2]}"
        # discard $unit
        unset unit
        # Check if number is valid for a percentage (> 1 and < 99)
        # me: "Nobody would seriously..." Layer 8: "Hold my beer!" 🍺
        if (( number < 1 )); then
            #prevent polluting the output
            unset title body
            # prepare new output
            local title body
            title=("❌ ${DISKGUARD_COLOR_RED}Error${DISKGUARD_COLOR_NC}")
            body=("${DISKGUARD_COLOR_YELLOW_BOLD}Threshold must be between 1-99!${DISKGUARD_COLOR_NC}
${DISKGUARD_COLOR_GREEN}Using the default value of 80%%.${DISKGUARD_COLOR_NC}")
            # display output
            diskguard_print_box \
            "${title[@]}" \
            "${body[@]}"
            val=80
            return 0
        elif (( number > 99 )); then
            #prevent polluting the output
            unset title body
            # prepare new output
            local title body
            title=("❌ ${DISKGUARD_COLOR_RED}Error${DISKGUARD_COLOR_NC}")
            body=("${DISKGUARD_COLOR_YELLOW_BOLD}A threshold above 99%% makes absolutely no sense.${DISKGUARD_COLOR_NC}
${DISKGUARD_COLOR_YELLOW_BOLD}Even 99%% is borderline, because it may already${DISKGUARD_COLOR_NC}
${DISKGUARD_COLOR_YELLOW_BOLD}be too late for a warning.${DISKGUARD_COLOR_NC}
${DISKGUARD_COLOR_GREEN}Using the default value of 80%%.${DISKGUARD_COLOR_NC}")
            # display output
            diskguard_print_box \
            "${title[@]}" \
            "${body[@]}"
            # using default value for $val
            val=80
            return 0
        else
            val=${number}
        fi
    # discard $number, as it is now $val
    unset number
    fi
    return 0
}
